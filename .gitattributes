# Enforce LF line endings for all text files.
* text=auto eol=lf

# Binary files that must never be modified by Git's line-ending handling.
*.whl binary
*.oso binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.zip binary
*.3mf binary
*.stl binary
*.glb binary
*.gltf binary
*.blend binary
